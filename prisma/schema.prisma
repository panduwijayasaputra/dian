generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

enum Role {
  ADMIN
  USER
}

enum DocumentStatus {
  LOCAL
  UPLOADING
  PROCESSING
  EXTRACTING
  REVIEW
  READY
  ERROR
}

enum DocumentType {
  INCOMING_LETTER
  OUTGOING_LETTER
  DISPOSITION
  MEMO
  REPORT
  DECREE
  OTHER
  SPT
  NOTA_DINAS
}

enum EmbeddingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ExtractionStatus {
  pending
  completed
  failed
  manual_only
}

enum UrgencyLevel {
  BIASA
  SEGERA
  SANGAT_SEGERA
}

enum SecurityLevel {
  BIASA
  TERBATAS
  RAHASIA
  SANGAT_RAHASIA
}

model User {
  id           String     @id @default(cuid())
  name         String
  username     String     @unique
  passwordHash String
  role         Role       @default(USER)
  isActive     Boolean    @default(true) @map("is_active")
  divisionId   String?    @map("division_id")
  division     Division?  @relation(fields: [divisionId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  documents    Document[]
  activityLogs ActivityLog[]
  chatSessions ChatSession[]
}

model Division {
  id                String             @id @default(cuid())
  name              String             @unique
  color             String             @default("blue")
  createdAt         DateTime           @default(now())
  users             User[]
  documentDivisions DocumentDivision[]
}

model Document {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id])
  r2Key          String?
  status         DocumentStatus @default(UPLOADING)
  documentType   DocumentType?
  documentNumber String?
  documentDate   DateTime?
  sender         String?
  receiver       String?
  subject        String?
  urgency        UrgencyLevel?
  security       SecurityLevel?
  deadlineStart  DateTime?
  deadlineEnd    DateTime?
  fileSizeBytes    Int?
  originalName     String?
  extractedText    String?
  extractionResult Json?
  summary          String?
  memo             String?
  embeddingStatus  EmbeddingStatus  @default(PENDING)
  extractionStatus ExtractionStatus @default(pending)
  chunks           DocumentChunk[]
  divisions        DocumentDivision[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model DocumentDivision {
  id         String   @id @default(cuid())
  documentId String   @map("document_id")
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  divisionId String   @map("division_id")
  division   Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)

  @@unique([documentId, divisionId])
}

model DocumentChunk {
  id         String                    @id @default(cuid())
  documentId String
  document   Document                  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content    String
  chunkIndex Int
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime                  @default(now())
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String        @map("user_id")
  user      User          @relation(fields: [userId], references: [id])
  title     String
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  messages  ChatMessage[]

  @@index([userId])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String      @map("session_id")
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String
  sources   Json?
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([sessionId])
  @@map("chat_messages")
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  resourceId  String?
  information String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
